{
  "name": "email-triage",
  "display_name": "Email Triage",
  "version": "1.2.1",
  "description": "Automated Gmail inbox triage with configurable categories, priority detection, iterative training, and summary delivery via Slack or chat.",
  "author": "agent-index",
  "license": "proprietary",
  "category": "communication",
  "agent_index_min_version": "3.0.0",
  "api": [
    {"name":"email-triage","triggers":[{"phrase":"triage my email","capability":"email-triage","description":"Run inbox triage with priority detection"},{"phrase":"check my inbox","capability":"email-triage","description":"Scan and categorize recent emails"},{"phrase":"what's important in my email","capability":"email-triage","description":"Surface high-priority emails"},{"phrase":"process my email","capability":"email-triage","description":"Run the full email triage workflow"}]},
    {"name":"email-triage-config","triggers":[{"phrase":"configure email triage","capability":"email-triage-config","description":"Adjust email triage categories and settings"},{"phrase":"change my email settings","capability":"email-triage-config","description":"Modify email triage configuration"}]},
    {"name":"email-triage-train","triggers":[{"phrase":"train email triage","capability":"email-triage-train","description":"Improve triage accuracy with feedback"},{"phrase":"email triage got this wrong","capability":"email-triage-train","description":"Correct a misclassified email"}]},
    {"name":"email-digest","triggers":[{"phrase":"email digest","capability":"email-digest","description":"Generate a summary digest of recent emails"},{"phrase":"summarize my emails","capability":"email-digest","description":"Create a condensed email overview"}]},
    {"name":"email-triage-tutorial","triggers":[{"phrase":"how does email triage work","capability":"email-triage-tutorial","description":"Learn how to use email triage features"}]}
  ],
  "dependencies": [],
  "external_dependencies": [
    {
      "system": "Gmail MCP",
      "access_required": "Gmail search and read access (gmail_search, gmail_get_message, gmail_get_thread)",
      "contact": "org admin",
      "required": true
    },
    {
      "system": "Gmail API OAuth credentials",
      "access_required": "Google Cloud OAuth2 credentials.json with gmail.modify scope, provided by org admin at collection install time. Members authorize their own accounts against it during member setup.",
      "contact": "org admin",
      "required": true
    },
    {
      "system": "Slack MCP",
      "access_required": "Slack message sending (slack_send_message). Only required if delivery_method is 'slack'.",
      "contact": "org admin",
      "required": false
    }
  ],
  "eol_date": null,
  "marketplace_url": "https://github.com/agent-index/agent-index-marketplace-email-triage",
  "support_url": "https://agent-index.ai/support"
}
